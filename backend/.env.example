# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ──────────────────────────────────────────────────────────────────
# Local (Docker):
DATABASE_URL=postgresql://parabox:parabox@localhost:5432/parabox_dev
# Production (NeonDB — copy from dashboard):
# DATABASE_URL=postgresql://user:pass@ep-xxx-xxx.neon.tech/parabox?sslmode=require

# ─── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:4200

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Email ─────────────────────────────────────────────────────────────────────
# Development — MailHog (SMTP on 1025, web UI on http://localhost:8025)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=noreply@parabox.local
# Production — Resend:
# RESEND_API_KEY=re_xxxxxxxxxxxx

# ─── Temporary accounts ────────────────────────────────────────────────────────
ACCOUNT_TTL_DAYS=7
