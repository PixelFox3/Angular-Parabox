# Angular reads environment variables at build time via src/environments/
# Copy environment.ts and update the apiUrl before running the app.
#
# Development:  http://localhost:3000/api
# Production:   https://parabox-api.up.railway.app/api  ← set in Railway dashboard
#
# Usage: copy src/environments/environment.ts → environment.prod.ts
#        and set apiUrl to the production Railway URL.
