{
    "name": "parabox",
    "version": "0.1.0",
    "private": true,
    "description": "Angular E-Commerce Showcase – Monorepo (frontend + backend + shared)",
    "scripts": {
        "frontend:install": "npm install --prefix frontend",
        "frontend:start": "npm start --prefix frontend",
        "frontend:build": "npm run build --prefix frontend",
        "frontend:test": "npm test --prefix frontend",
        "backend:install": "npm install --prefix backend",
        "backend:start": "npm run start:dev --prefix backend",
        "backend:build": "npm run build --prefix backend",
        "docker:up": "docker compose up",
        "docker:down": "docker compose down"
    }
}